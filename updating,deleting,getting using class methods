class Shopping_cart:
    def __init__(self):
        self.items={}
    def cart_items(self,item_name ,quantity):
        self.items[item_name]=quantity
    def remove_item(self,item_name):
        del self.items[item_name]
    def update_item(self,item_name,new_quantity):
        self.items[item_name]=new_quantity
    def get_cart_items(self):
        get_cart_item=list(self.items.keys())
        return get_cart_item
obj_shopping_cart=Shopping_cart()
obj_shopping_cart.cart_items("Apple",5)
