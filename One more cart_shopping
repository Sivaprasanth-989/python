class cart:
    def __init__(self):
        self.items={}
    def select_items(self,product_name,quantity):
        self.items[product_name]=quantity
    def update_items(self,product_name,updated_quantity):
        self.items[product_name]=updated_quantity
    def delete_item(self,product_name):
        del self.items[product_name]
    def get_items(self):
        get_items=list(self.items.keys())
        return get_items
cart_obj=cart()
cart_obj.select_items("Wonder women",22)
print(cart_obj.get_items())
print(cart_obj.items)
cart_obj.update_items("Superman ",26)
print(cart_obj.items)
cart_obj.delete_item("Wonder women")
print(cart_obj.items)
